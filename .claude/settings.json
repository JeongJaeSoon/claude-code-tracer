{
	"permissions": {
		"allow": [
			"Skill(frontend-design)",
			"Bash(git add:*)",
			"Bash(git commit:*)",
			"Bash(bunx tsc:*)",
			"Bash(bun run dev:*)",
			"Bash(bun run build:*)",
			"Bash(bun run format:*)",
			"Bash(bun add:*)"
		]
	},
	"hooks": {
		"PostToolUse": [
			{
				"matcher": "Write|Edit",
				"hooks": [
					{
						"type": "command",
						"command": "bun run format || true"
					}
				]
			}
		]
	}
}
