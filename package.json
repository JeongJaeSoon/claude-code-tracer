{
  "name": "claude-code-tracer",
  "version": "0.1.0",
  "description": "Self-hosted tracing solution for Claude Code sessions",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun run --watch src/server/index.ts",
    "dev:client": "vite",
    "build": "vite build && bun build src/server/index.ts --outdir dist/server --target bun",
    "start": "bun run dist/server/index.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "hono": "^4.6.0",
    "drizzle-orm": "^0.36.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "flame-chart-js": "^3.0.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "drizzle-kit": "^0.30.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0"
  }
}
