{
	"name": "claude-code-tracer",
	"version": "0.1.0",
	"description": "Self-hosted tracing solution for Claude Code sessions",
	"type": "module",
	"private": true,
	"scripts": {
		"dev:server": "bun run --watch src/server/index.ts",
		"dev:client": "vite",
		"build": "vite build && bun build src/server/index.ts --outdir dist/server --target bun",
		"start": "bun run dist/server/index.js",
		"format": "biome format --write .",
		"lint": "biome lint .",
		"check": "biome check --write .",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:studio": "drizzle-kit studio"
	},
	"dependencies": {
		"drizzle-orm": "^0.36.0",
		"flame-chart-js": "^3.0.0",
		"hono": "^4.6.0",
		"react": "^19.0.0",
		"react-dom": "^19.0.0",
		"react-markdown": "^10.1.0",
		"react-syntax-highlighter": "^16.1.0",
		"remark-gfm": "^4.0.1"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.3.11",
		"@types/bun": "latest",
		"@types/react": "^19.0.0",
		"@types/react-dom": "^19.0.0",
		"@types/react-syntax-highlighter": "^15.5.13",
		"@vitejs/plugin-react": "^4.3.0",
		"drizzle-kit": "^0.30.0",
		"typescript": "^5.6.0",
		"vite": "^6.0.0"
	}
}
